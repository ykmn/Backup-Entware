#!/opt/bin/sh
# v2026-07-01
set -e
# use sed -i 's/\r//g' /opt/etc/cron.daily/backup to fix Windows CR/LF line ends

PATH=/opt/bin:/opt/sbin:/sbin:/bin:/usr/sbin:/usr/bin

### Settings
USB_LABEL="Kingston16G"
BACKUP_DIR="/tmp/mnt/${USB_LABEL}/Backups"
DAYS=8
TAG=Backup

# Select components
IsNFQWS1=0
IsNFQWS2=1
IsSKeen=0
IsXKeen=1
IsXKeenUI=1
IsMihomo=1
IsXRay=0
IsConf=1
IsFirm=1
# ====================




# Exclude this strings for grep running-config
EXCLCONFCMD='!\$\$\$\|clock date'

if [ -t 1 ]; then
	RESET='\033[0m'    CYAN='\033[36m'    GREEN='\033[32m'
	YELLOW='\033[33m'  RED='\033[31m'     BOLD_RED='\033[1;31m'
	BOLD_YELLOW='\033[1;33m'              GRAY='\033[90m'
else
	RESET='' CYAN='' GREEN='' YELLOW='' RED='' BOLD_RED='' BOLD_YELLOW='' GRAY=''
fi

EchoLog() {
	local message="$1" color="$RESET"
	case "$message" in
		*"Starting"*)                      color="$CYAN" ;;
		*"complete"|"Done"|"finished"*)    color="$GREEN" ;;
		*"Skipping"*)                      color="$GRAY" ;;
		*"Warning"*)                       color="$YELLOW" ;;
		*"Error"*)                         color="$BOLD_RED" ;;
		*"changed"*)                       color="$BOLD_YELLOW" ;;
		*"is not changed"*)                color="$GRAY" ;;
	esac
	logger -t "$TAG" "$message"
	printf '%b\n' "${color}${TAG}: ${message}${RESET}"
}

# Check architecture
ARCH=$(opkg print-architecture 2>/dev/null | awk '/^arch/ && $2 !~ /^(all|noarch)$/ {print $2; exit}')
if [ -z "$ARCH" ]; then
	# fallback: read from binary
	ARCH=$(readelf -h /opt/bin/opkg 2>/dev/null | awk '/Machine:/ {print $2}') || ARCH="unknown"
fi


# Check destination flash drive
if [ ! -d "/tmp/mnt/${USB_LABEL}" ]; then
	EchoLog "Error: USB drive '${USB_LABEL}' not mounted!"
	exit 1
fi

AVAIL=$(df -k "$BACKUP_DIR" 2>/dev/null | awk 'NR==2 {print $4}')
TOTAL_OPT=$(du -sk /opt 2>/dev/null | awk '{print $1}')
if [ -n "$AVAIL" ] && [ -n "$TOTAL_OPT" ] && [ "$AVAIL" -lt "$TOTAL_OPT" ]; then
	EchoLog "Error: Only $((AVAIL / 1024)) MiB free, need ~$((TOTAL_OPT / 1024)) MiB"
	exit 1
fi


### Apps Backup function:
backup_app() {
	local name="$1" enabled="$2"
	shift 2
	[ "$enabled" != "1" ] && { EchoLog "Skipping ${name} backup"; return 0; }
	EchoLog "Starting ${name} backup"
	while [ $# -ge 2 ]; do
		local src="$1" dst="$2"
		shift 2
		[ ! -e "$src" ] && { EchoLog "Warning: ${name}: ${src} not found, skipping"; continue; }
		mkdir -p "${DATEDIR}${dst%/*}" || { EchoLog "Error: mkdir failed for ${name}."; exit 1; }
		cp -rf "$src" "${DATEDIR}${dst}" || { EchoLog "Error: ${name} copy failed"; exit 1; }
	done
	EchoLog "${name} backup complete"
}



# Start!

DATE=$(date +%Y-%m-%d)
DATEDIR="${BACKUP_DIR}/${DATE}/"
mkdir -p "$DATEDIR" || { EchoLog "Error: Cannot create $DATEDIR."; exit 1; }

START_TIME=$(date +%s)
EchoLog "Starting backup | arch: ${ARCH} | target: ${BACKUP_DIR}"

# Backup Apps!

cd /opt

backup_app "NFQWS1" "$IsNFQWS1" \
	"/opt/etc/nfqws" "etc/nfqws"

backup_app "NFQWS2" "$IsNFQWS2" \
	"/opt/etc/nfqws2" "etc/nfqws2"

backup_app "SKeen" "$IsSKeen" \
	"/opt/etc/skeen/skeen.json" "etc/skeen/skeen.json" \
	"/opt/etc/skeen/config" "etc/skeen/config"

backup_app "Mihomo" "$IsMihomo" \
	"/opt/etc/mihomo/config.yaml" "etc/mihomo/config.yaml"

backup_app "XKeen" "$IsXKeen" \
	"/opt/etc/xkeen" "etc/xkeen"

backup_app "XKeenUI" "$IsXKeenUI" \
	"/opt/etc/xkeen-ui" "etc/xkeen-ui"

backup_app "XRay" "$IsXRay" \
	"/opt/etc/xray/configs" "etc/xray/configs"



# Complete backup of Entware image

ARCHIVE="${ARCH}-installer-${DATE}.tar.gz"
EchoLog "Starting Entware archive: ${ARCHIVE}"
EXCLUDE="--exclude=opt/tmp --exclude=opt/var/run"

if [ -t 1 ] && command -v pv >/dev/null 2>&1; then
	TOTAL_SIZE=$(du -sk /opt 2>/dev/null | awk '{print $1}')
	if [ -n "$TOTAL_SIZE" ] && [ "$TOTAL_SIZE" -gt 0 ] 2>/dev/null; then
		# shellcheck disable=SC2086
		tar -cf - -C / $EXCLUDE opt/ \
			| pv -s "${TOTAL_SIZE}k" -N "Archiving" | gzip \
			> "${DATEDIR}${ARCHIVE}"
	else
		# shellcheck disable=SC2086
		tar -cf - -C / $EXCLUDE opt/ \
			| pv -N "Archiving" | gzip \
			> "${DATEDIR}${ARCHIVE}"
	fi
else
	# shellcheck disable=SC2086
	tar -czf "${DATEDIR}${ARCHIVE}" -C / $EXCLUDE opt/
fi
EchoLog "Entware archive complete"


# Backup running-config ---

if [ "$IsConf" = "1" ]; then
	EchoLog "Starting running-config backup"
	CONFIG_NEW="${DATEDIR}config-${DATE}"
	CONFIG_CUR="${BACKUP_DIR}/config-cur"

	if ! command -v ndmc >/dev/null 2>&1; then
		EchoLog "Warning: ndmc not found, skipping running-config backup"
	else
		ndmc -c "show running-config" > "$CONFIG_NEW" || { EchoLog "Error: ndmc failed"; exit 1; }

		if [ -f "$CONFIG_CUR" ]; then
		OLDCONF=$(grep -v "${EXCLCONFCMD}" "$CONFIG_CUR") || true
		CURCONF=$(grep -v "${EXCLCONFCMD}" "$CONFIG_NEW") || true
		if [ "$OLDCONF" = "$CURCONF" ]; then
			EchoLog "Running config is not changed"
			rm -f "$CONFIG_NEW"
		else
			EchoLog "Running config changed. Saving."
			cp -rf "$CONFIG_NEW" "$CONFIG_CUR"
			gzip -f "$CONFIG_NEW"
		fi
	else
		EchoLog "First run — saving running-config"
		cp -rf "$CONFIG_NEW" "$CONFIG_CUR"
		gzip -f "$CONFIG_NEW"
	fi
	fi
fi

# Firmware
if [ "$IsFirm" = "1" ]; then
	EchoLog "Starting firmware backup"

	if ! command -v ndmc >/dev/null 2>&1; then
		EchoLog "Warning: ndmc not found, skipping firmware backup"
	else
		FIRM_NEW="${DATEDIR}firmware-${DATE}"
		FIRM_CUR="${BACKUP_DIR}/firmware-cur"
		USB_RELPATH="${BACKUP_DIR#/tmp/mnt/${USB_LABEL}/}"

		ndmc -c "copy flash:/firmware ${USB_LABEL}:${USB_RELPATH}/${DATE}/firmware-${DATE}" \
			|| { EchoLog "Error: ndmc copy failed for firmware."; exit 1; }

		if [ -f "$FIRM_NEW" ]; then
			if [ -f "$FIRM_CUR" ] && cmp -s "$FIRM_CUR" "$FIRM_NEW"; then
				EchoLog "Firmware is not changed. No new archive needed."
				rm -f "$FIRM_NEW"
			else
				EchoLog "Firmware is changed. Saving."
				cp -f "$FIRM_NEW" "$FIRM_CUR"
			fi
		else
			EchoLog "Warning: firmware file not found at ${FIRM_NEW}"
		fi
	fi
else
	EchoLog "Skipping firmware backup"
fi

# Cleanup

cd "$BACKUP_DIR"
EchoLog "Removing backups older than ${DAYS} days"
find "$BACKUP_DIR" -maxdepth 1 -type d -mtime +${DAYS} -exec rm -rf {} \; 2>/dev/null || true

END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))
SIZE=$(du -sh "${DATEDIR}" 2>/dev/null | awk '{print $1}')

EchoLog "Backup finished | size: ${SIZE} | duration: $((DURATION / 60))m $((DURATION % 60))s"
